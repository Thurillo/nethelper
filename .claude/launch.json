{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "NetHelper Frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["frontend/node_modules/vite/bin/vite.js", "frontend", "--port", "5173"],
      "port": 5173
    },
    {
      "name": "NetHelper Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000", "--app-dir", "backend"],
      "port": 8000
    }
  ]
}
